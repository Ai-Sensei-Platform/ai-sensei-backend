{
  "name": "ai-voice-tutor-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Clean-architecture backend for the AI Voice Tutor for Documents — TypeScript, TypeORM, PostgreSQL, S3.",
  "type": "commonjs",
  "main": "dist/main.js",
  "engines": {
    "node": ">=18.18"
  },
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "eval:citations": "tsx scripts/eval-citations.ts",
    "build": "tsc -p tsconfig.json && tsc-alias -p tsconfig.json",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit",
    "typeorm": "typeorm-ts-node-commonjs",
    "migration:generate": "npm run typeorm -- migration:generate ./src/infrastructure/database/migrations/migrations -d ./src/infrastructure/database/data-source.ts",
    "migration:run": "npm run typeorm migration:run -- -d ./src/infrastructure/database/data-source.ts",
    "migration:revert": "npm run typeorm migration:revert -- -d ./src/infrastructure/database/data-source.ts",
    "migration:show": "npm run typeorm migration:show -- -d ./src/infrastructure/database/data-source.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.668.0",
    "@aws-sdk/s3-request-presigner": "^3.1079.0",
    "@napi-rs/canvas": "^0.1.65",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "express-validator": "^7.3.2",
    "google-auth-library": "^10.7.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "openai": "^6.44.0",
    "pdfjs-dist": "^4.7.76",
    "pg": "^8.13.1",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^0.3.20"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.9.0",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.10",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
