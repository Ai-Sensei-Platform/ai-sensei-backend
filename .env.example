# ─── HTTP ──────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# Comma-separated origins allowed to call the API (the Vite dev server).
CORS_ORIGINS=http://localhost:5173

# ─── PostgreSQL ────────────────────────────────────────────────────────────
DATABASE_URL=postgres://tutor:tutor@localhost:5432/ai_voice_tutor
# Auto-create schema from entities (development only). Use migrations in prod.
DB_SYNCHRONIZE=true
DB_LOGGING=false

# ─── AWS S3 / object storage ──────────────────────────────────────────────
S3_BUCKET=ai-voice-tutor
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# ─── OpenAI ────────────────────────────────────────────────────────────────
# Powers the agentic tutor, embeddings, text-to-speech, and transcription.
# Optional: when blank, the tutor streams a local demo answer and voice I/O
# is disabled (the front-end falls back to the browser's speech APIs).
OPENAI_API_KEY=
# Tutor model, and the cheaper model used in "save-cost mode".
OPENAI_TUTOR_MODEL=gpt-5.4-mini
OPENAI_TUTOR_MODEL_SAVE_COST=gpt-5-nano
# Embedding model for document chunks and search queries.
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# Speech-to-text and text-to-speech.
OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe
OPENAI_SPEECH_MODEL=gpt-4o-mini-tts
OPENAI_SPEECH_VOICE=alloy

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

ACCESS_TOKEN_TTL=1d
REFRESH_TOKEN_TTL=7d

FRONTEND_URL=http://localhost:5173
